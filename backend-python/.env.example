# Application Settings
APP_NAME="agent-backend"
DEBUG=false
VERSION="1.0.0"
SERVER_PORT=8080

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost/interviewready"

# Google Cloud / Vertex AI Configuration
GOOGLE_PROJECT_ID="architecting-ai-systems-e71af"
GOOGLE_LOCATION="us-central1"
GOOGLE_CREDENTIALS_URI=null

# Gemini Model Configuration
GEMINI_MODEL="gemini-2.5-flash"
GOOGLE_API_KEY="your-google-api-key"

# Firebase Configuration
FIREBASE_ENABLED=false
FIREBASE_CONFIG_PATH="classpath:architecting-ai-systems-e71af-firebase-adminsdk-fbsvc-0033ba2601.json"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY_ID="your-private-key-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
FIREBASE_CLIENT_ID="your-client-id"

# Security Configuration
SECURITY_FILTER_ORDER=5

# CORS Configuration
ALLOWED_HOSTS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Logging & Monitoring
LOG_LEVEL="DEBUG"
LOGGERS=["app"]
ENABLE_HEALTH_ENDPOINT=true
ENABLE_INFO_ENDPOINT=true
ENABLE_METRICS_ENDPOINT=true

# LangGraph Configuration (optional)
LANGGRAPH_API_KEY="your-langgraph-api-key"
