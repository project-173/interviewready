# Application Settings
APP_NAME="agent-backend"
VERSION="1.0.0"
SERVER_PORT=8080

# Google Cloud / Vertex AI Configuration
GOOGLE_PROJECT_ID="architecting-ai-systems-e71af"
GOOGLE_LOCATION="us-central1"
GOOGLE_CREDENTIALS_URI=null

# Gemini Model Configuration
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_KEY="your-gemini-api-key"

# CORS Configuration
ALLOWED_HOSTS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Mock agent response
MOCK_RESUME_CRITIC_AGENT=true
MOCK_EXTRACTOR_AGENT=true
MOCK_CONTENT_STRENGTH_AGENT=true
MOCK_JOB_ALIGNMENT_AGENT=true
MOCK_INTERVIEW_COACH_AGENT=true

# Logging & Monitoring
LOG_LEVEL="DEBUG"
LOGGERS=["app"]
ENABLE_HEALTH_ENDPOINT=true
ENABLE_INFO_ENDPOINT=true
ENABLE_METRICS_ENDPOINT=true